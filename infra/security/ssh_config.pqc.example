# Client-side OpenSSH hybrid-PQ readiness example for staging validation.
# Do not replace a user's global SSH config without explicit approval.

Host aura-staging
  HostName staging.example.invalid
  User deploy
  IdentitiesOnly yes
  PubkeyAuthentication yes
  KexAlgorithms mlkem768x25519-sha256,sntrup761x25519-sha512,sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org
  HostKeyAlgorithms ssh-ed25519,rsa-sha2-512,rsa-sha2-256
  PubkeyAcceptedAlgorithms sk-ssh-ed25519@openssh.com,ssh-ed25519,rsa-sha2-512,rsa-sha2-256
  StrictHostKeyChecking yes
