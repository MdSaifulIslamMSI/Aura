# Safe OpenSSH hybrid-PQ readiness example.
# Copy into a staging host only after validating OpenSSH support and keeping
# emergency console rollback access.

Protocol 2
PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
PermitEmptyPasswords no
AllowTcpForwarding no
X11Forwarding no
MaxAuthTries 3
LoginGraceTime 30

# Preferred where OpenSSH 10+ supports these algorithms. Keep classical
# fallback during staged rollout so existing deploys are not broken.
KexAlgorithms mlkem768x25519-sha256,sntrup761x25519-sha512,sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org

HostKeyAlgorithms ssh-ed25519,rsa-sha2-512,rsa-sha2-256
PubkeyAcceptedAlgorithms sk-ssh-ed25519@openssh.com,ssh-ed25519,rsa-sha2-512,rsa-sha2-256
