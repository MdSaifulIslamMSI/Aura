global
  maxconn 4096

defaults
  mode http
  timeout connect 5s
  timeout client 30s
  timeout server 30s

frontend aura_api
  bind :443 ssl crt /etc/haproxy/certs/aura.pem
  stick-table type ip size 200k expire 10m store http_req_rate(10s),conn_cur
  http-request track-sc0 src
  http-request deny deny_status 429 if { sc_http_req_rate(0) gt 200 }
  http-request deny deny_status 429 if { path_beg /api/auth/ } { sc_http_req_rate(0) gt 30 }
  default_backend aura_origin

backend aura_origin
  option httpchk GET /health/live
  server api1 127.0.0.1:5000 check maxconn 512
