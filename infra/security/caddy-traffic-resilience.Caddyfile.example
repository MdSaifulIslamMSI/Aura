api.example.invalid {
    encode zstd gzip

    request_body {
        max_size 10MB
    }

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer
    }

    reverse_proxy 127.0.0.1:5000 {
        transport http {
            dial_timeout 5s
            response_header_timeout 15s
        }
        lb_try_duration 10s
    }
}
