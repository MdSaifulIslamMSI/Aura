limit_req_zone $binary_remote_addr zone=aura_public:20m rate=20r/s;
limit_req_zone $binary_remote_addr zone=aura_login:10m rate=2r/s;
limit_conn_zone $binary_remote_addr zone=aura_conn:20m;

server {
    listen 443 ssl http2;
    server_name api.example.invalid;

    client_body_timeout 10s;
    client_header_timeout 10s;
    keepalive_timeout 20s;
    large_client_header_buffers 4 16k;

    limit_conn aura_conn 40;

    location /api/auth/ {
        limit_req zone=aura_login burst=5 nodelay;
        proxy_pass http://127.0.0.1:5000;
    }

    location /api/ {
        limit_req zone=aura_public burst=80 nodelay;
        proxy_pass http://127.0.0.1:5000;
    }
}
