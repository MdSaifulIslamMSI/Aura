# Caddy TLS 1.3 readiness example for staging and edge review.
# Browser-facing hybrid PQC is ecosystem-dependent; do not force OQS/liboqs here.

example.invalid {
  tls {
    protocols tls1.3
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
  }

  reverse_proxy 127.0.0.1:5000
}
