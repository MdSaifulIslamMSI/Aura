# Azure App Service API settings
# Secrets should come from Key Vault references, not raw values.

NODE_ENV=production
PORT=8080
APP_PUBLIC_URL=https://api.example.com
CORS_ORIGIN=https://app.example.com,https://www.example.com
FRONTEND_URL=https://app.example.com
JSON_BODY_LIMIT=12mb
REQUEST_TIMEOUT_MS=30000
BOOT_GRACE_PERIOD_SEC=900
GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000

SPLIT_RUNTIME_ENABLED=true
REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_PREFIX=aura
REDIS_CONNECT_TIMEOUT_MS=3000
DISTRIBUTED_SECURITY_CONTROLS_ENABLED=true

MONGO_URI=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=mongo-uri)
REDIS_URL=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=redis-url)

CRON_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=cron-secret)
METRICS_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=metrics-secret)

FIREBASE_PROJECT_ID=<firebase-project-id>
FIREBASE_SERVICE_ACCOUNT=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=firebase-service-account)

AUTH_VAULT_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=auth-vault-secret)
AUTH_VAULT_SECRET_VERSION=v1
AUTH_VAULT_PREVIOUS_SECRETS=
AUTH_LATTICE_CHALLENGE_MODE=off
AUTH_REQUIRE_OTP_FOR_ALL_PROTECTED=false

UPLOAD_SIGNING_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=upload-signing-secret)
OTP_FLOW_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=otp-flow-secret)
OTP_CHALLENGE_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=otp-challenge-secret)

CSRF_STRICT_CLIENT_SIGNALS=true
ADMIN_STRICT_ACCESS_ENABLED=true
ADMIN_REQUIRE_EMAIL_VERIFIED=true
ADMIN_REQUIRE_FRESH_LOGIN_MINUTES=30
ADMIN_REQUIRE_2FA=false
ADMIN_REQUIRE_ALLOWLIST=false
ADMIN_ALLOWLIST_EMAILS=

PAYMENTS_ENABLED=true
PAYMENT_PROVIDER=razorpay
PAYMENT_RISK_MODE=shadow
PAYMENT_CAPTURE_MODE=post_order_auth_capture
PAYMENT_SAVED_METHODS_ENABLED=true
PAYMENT_REFUNDS_ENABLED=true
PAYMENT_CHALLENGE_ENABLED=true
PAYMENT_DYNAMIC_ROUTING_ENABLED=true
PAYMENT_WEBHOOKS_ENABLED=true
RAZORPAY_KEY_ID=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=razorpay-key-id)
RAZORPAY_KEY_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=razorpay-key-secret)
RAZORPAY_WEBHOOK_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=razorpay-webhook-secret)

ORDER_EMAILS_ENABLED=true
ORDER_EMAIL_PROVIDER=resend
ORDER_EMAIL_FROM_NAME=Aura Marketplace
ORDER_EMAIL_FROM_ADDRESS=no-reply@example.com
ORDER_EMAIL_REPLY_TO=support@example.com
ORDER_EMAIL_ALERT_TO=ops@example.com
ORDER_EMAIL_MAX_RETRIES=8
ORDER_EMAIL_WORKER_POLL_MS=10000
RESEND_API_KEY=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=resend-api-key)
RESEND_WEBHOOK_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=resend-webhook-secret)
GMAIL_USER=
GMAIL_APP_PASSWORD=

EMAIL_SECURITY_ENABLED=true
EMAIL_SECURITY_STRICT_MODE=true
EMAIL_SECURITY_ALLOWED_EVENT_TYPES=otp_security,order_placed,order_refund_processed
EMAIL_SECURITY_ALLOW_HTML=true
EMAIL_SECURITY_MAX_SUBJECT_LEN=140
EMAIL_SECURITY_MAX_TEXT_LEN=20000
EMAIL_SECURITY_MAX_HTML_LEN=250000

OTP_EMAIL_FAIL_CLOSED=true
OTP_EMAIL_CONTEXT_ENABLED=true
OTP_EMAIL_TTL_MINUTES=5
OTP_EMAIL_SEND_IN_TEST=false
OTP_LOGIN_REQUIRE_CREDENTIAL_PROOF=true
OTP_LOGIN_AUTO_RECOVER_PROFILE=true

OTP_SMS_ENABLED=true
OTP_SMS_PROVIDER=twilio
OTP_SMS_FAIL_CLOSED=true
OTP_SMS_SEND_IN_TEST=false
OTP_WHATSAPP_ENABLED=false
OTP_SMS_TTL_MINUTES=5
OTP_SMS_DEFAULT_COUNTRY_CODE=+91
OTP_SMS_BRAND=AURA
TWILIO_ACCOUNT_SID=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=twilio-account-sid)
TWILIO_AUTH_TOKEN=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=twilio-auth-token)
TWILIO_FROM_NUMBER=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=twilio-from-number)
TWILIO_WHATSAPP_FROM=
TWILIO_STATUS_CALLBACK_URL=

GROQ_API_KEY=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=groq-api-key)
GROQ_CHAT_MODEL=openai/gpt-oss-20b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_AUDIO_MODEL=whisper-large-v3-turbo
GROQ_MODERATION_MODEL=
GROQ_REQUEST_TIMEOUT_MS=20000
GROQ_RETRY_DELAY_MS=750
GROQ_MAX_RETRIES=2

VOYAGE_API_KEY=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=voyage-api-key)
VOYAGE_TEXT_EMBEDDING_MODEL=voyage-3.5-lite
VOYAGE_RERANK_MODEL=rerank-2.5-lite
VOYAGE_REQUEST_TIMEOUT_MS=15000
VOYAGE_RETRY_DELAY_MS=500
VOYAGE_MAX_RETRIES=2

ELEVENLABS_API_KEY=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=elevenlabs-api-key)
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_REQUEST_TIMEOUT_MS=15000

LIVEKIT_URL=
LIVEKIT_API_KEY=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=livekit-api-key)
LIVEKIT_API_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=livekit-api-secret)
LIVEKIT_TTL_SECONDS=3600
LIVEKIT_ROOM_NAME=aura

AI_DEFAULT_LOCALE=en-IN
CHAT_USER_WINDOW_MS=900000
CHAT_USER_MAX_REQUESTS=60

CENTRAL_INTELLIGENCE_MODE=always
INTELLIGENCE_SERVICE_URL=https://intelligence.example.com
INTELLIGENCE_SERVICE_TIMEOUT_MS=12000
INTELLIGENCE_SERVICE_STREAM_TIMEOUT_MS=45000
INTELLIGENCE_SERVICE_TOKEN=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=intelligence-service-token)
AI_INTERNAL_TOOL_SECRET=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=ai-internal-tool-secret)
INTELLIGENCE_PROVIDER=huggingface_inference_client
INTELLIGENCE_ROUTING_MODEL=google/gemma-4-31B-it:novita
INTELLIGENCE_REASONING_MODEL=google/gemma-4-31B-it:novita
INTELLIGENCE_ENDPOINT_API_KEY=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=intelligence-endpoint-api-key)
INTELLIGENCE_EMBEDDING_ENDPOINT_FORMAT=deterministic
INTELLIGENCE_EMBEDDING_MODEL=intfloat/multilingual-e5-large
INTELLIGENCE_EMBEDDING_VECTOR_SIZE=256
INTELLIGENCE_EMBEDDING_BATCH_SIZE=32
QDRANT_URL=https://example-qdrant.cloud.qdrant.io:6333
QDRANT_API_KEY=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=qdrant-api-key)
QDRANT_COLLECTION_PREFIX=aura_code_chunks
QDRANT_DISTANCE=Cosine
QDRANT_UPSERT_BATCH_SIZE=128
NEO4J_URL=neo4j+s://example.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=neo4j-password)
NEO4J_DATABASE=neo4j
NEO4J_BATCH_SIZE=250
APP_BUILD_SHA=

ACTIVITY_EMAILS_ENABLED=true
ACTIVITY_EMAIL_COOLDOWN_SEC=0
ACTIVITY_EMAIL_MAX_HIGHLIGHTS=6
ACTIVITY_EMAIL_EXCLUDED_PATHS=/health,/metrics
ACTIVITY_EMAIL_CTA_URL=https://app.example.com/profile

CATALOG_IMPORTS_ENABLED=true
CATALOG_SYNC_ENABLED=true
CATALOG_ACTIVE_VERSION_REQUIRED=true
CATALOG_PUBLIC_DEMO_FALLBACK=false
CATALOG_SEARCH_INDEX_NAME=products_search_v1
CATALOG_SEARCH_CHECK_ON_BOOT=true
CATALOG_IMPORT_WORKER_POLL_MS=5000
CATALOG_SYNC_INTERVAL_MS=900000
CATALOG_DEFAULT_SYNC_PROVIDER=file
CATALOG_PROVIDER_SOURCE_REF=
CATALOG_PROVIDER_MANIFEST_REF=
CATALOG_IMPORT_AUDIT_SAMPLE_SIZE=1000
CATALOG_IMPORT_ALLOW_SYNTHETIC=false
CATALOG_READINESS_REQUIRE_PUBLISHED=true

COMMERCE_RECONCILIATION_ENABLED=true
COMMERCE_RECONCILIATION_POLL_MS=30000

CLIENT_DIAGNOSTIC_RETENTION_SEC=1209600

UPLOAD_STORAGE_DRIVER=azure-blob
AZURE_STORAGE_CONNECTION_STRING=@Microsoft.KeyVault(VaultName=<keyvault-name>;SecretName=azure-storage-connection-string)
AZURE_STORAGE_CONTAINER_NAME=review-media
REVIEW_UPLOAD_MAX_BYTES=7340032
REVIEW_UPLOAD_DIR=/home/site/uploads/reviews
