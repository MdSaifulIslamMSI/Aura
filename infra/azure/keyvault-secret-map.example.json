{
  "shared": {
    "mongo-uri": {
      "envVars": ["MONGO_URI"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "MongoDB Atlas",
      "rotation": "preserve existing value initially"
    },
    "redis-url": {
      "envVars": ["REDIS_URL"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Azure Managed Redis",
      "rotation": "new on Azure"
    },
    "azure-storage-connection-string": {
      "envVars": ["AZURE_STORAGE_CONNECTION_STRING"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Azure Storage account",
      "rotation": "new on Azure"
    },
    "firebase-service-account": {
      "envVars": ["FIREBASE_SERVICE_ACCOUNT"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Firebase service account JSON",
      "rotation": "prefer new least-privilege credential for Azure"
    },
    "auth-vault-secret": {
      "envVars": ["AUTH_VAULT_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "preserve current value for first Azure deploy, rotate later with AUTH_VAULT_PREVIOUS_SECRETS"
    },
    "upload-signing-secret": {
      "envVars": ["UPLOAD_SIGNING_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "otp-flow-secret": {
      "envVars": ["OTP_FLOW_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "otp-challenge-secret": {
      "envVars": ["OTP_CHALLENGE_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "cron-secret": {
      "envVars": ["CRON_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "metrics-secret": {
      "envVars": ["METRICS_SECRET"],
      "consumers": ["api"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    }
  },
  "payments": {
    "razorpay-key-id": {
      "envVars": ["RAZORPAY_KEY_ID"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Razorpay dashboard",
      "rotation": "copy from provider, rotate after cutover if desired"
    },
    "razorpay-key-secret": {
      "envVars": ["RAZORPAY_KEY_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Razorpay dashboard",
      "rotation": "copy from provider, rotate after cutover if desired"
    },
    "razorpay-webhook-secret": {
      "envVars": ["RAZORPAY_WEBHOOK_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Razorpay dashboard",
      "rotation": "set new secret if webhook endpoint changes"
    }
  },
  "communications": {
    "resend-api-key": {
      "envVars": ["RESEND_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Resend dashboard",
      "rotation": "copy from provider"
    },
    "resend-webhook-secret": {
      "envVars": ["RESEND_WEBHOOK_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Resend webhook signing secret",
      "rotation": "set from the configured Resend webhook endpoint"
    },
    "gmail-app-password": {
      "envVars": ["GMAIL_APP_PASSWORD"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Google account",
      "rotation": "prefer migrating to Resend instead"
    },
    "twilio-account-sid": {
      "envVars": ["TWILIO_ACCOUNT_SID"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Twilio console",
      "rotation": "copy from provider"
    },
    "twilio-auth-token": {
      "envVars": ["TWILIO_AUTH_TOKEN"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Twilio console",
      "rotation": "copy from provider or regenerate if rotating"
    },
    "twilio-from-number": {
      "envVars": ["TWILIO_FROM_NUMBER"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Twilio console",
      "rotation": "copy from provider"
    }
  },
  "ai": {
    "intelligence-service-token": {
      "envVars": ["INTELLIGENCE_SERVICE_TOKEN"],
      "consumers": ["api", "intelligence"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate once, rotate with coordinated deploy"
    },
    "ai-internal-tool-secret": {
      "envVars": ["AI_INTERNAL_TOOL_SECRET"],
      "consumers": ["api", "intelligence"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate once, rotate with coordinated deploy"
    },
    "intelligence-endpoint-api-key": {
      "envVars": ["INTELLIGENCE_ENDPOINT_API_KEY"],
      "consumers": ["api", "intelligence"],
      "sourceOfTruth": "Hugging Face or managed inference provider",
      "rotation": "copy from provider and rotate there first"
    },
    "qdrant-api-key": {
      "envVars": ["QDRANT_API_KEY"],
      "consumers": ["api", "intelligence"],
      "sourceOfTruth": "Qdrant Cloud",
      "rotation": "copy from provider"
    },
    "neo4j-password": {
      "envVars": ["NEO4J_PASSWORD"],
      "consumers": ["api", "intelligence"],
      "sourceOfTruth": "Neo4j Aura",
      "rotation": "copy from provider"
    },
    "groq-api-key": {
      "envVars": ["GROQ_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Groq dashboard",
      "rotation": "copy from provider"
    },
    "voyage-api-key": {
      "envVars": ["VOYAGE_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Voyage dashboard",
      "rotation": "copy from provider"
    },
    "elevenlabs-api-key": {
      "envVars": ["ELEVENLABS_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "ElevenLabs dashboard",
      "rotation": "copy from provider"
    },
    "livekit-api-key": {
      "envVars": ["LIVEKIT_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "LiveKit dashboard",
      "rotation": "copy from provider"
    },
    "livekit-api-secret": {
      "envVars": ["LIVEKIT_API_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "LiveKit dashboard",
      "rotation": "copy from provider"
    }
  }
}
