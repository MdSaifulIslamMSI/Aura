{
  "shared": {
    "mongo-uri": {
      "envVars": ["MONGO_URI"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "MongoDB Atlas",
      "rotation": "preserve existing value initially"
    },
    "redis-url": {
      "envVars": ["REDIS_URL"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Azure Managed Redis",
      "rotation": "new on Azure"
    },
    "azure-storage-connection-string": {
      "envVars": ["AZURE_STORAGE_CONNECTION_STRING"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Azure Storage account",
      "rotation": "new on Azure"
    },
    "firebase-service-account": {
      "envVars": ["FIREBASE_SERVICE_ACCOUNT"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Firebase service account JSON",
      "rotation": "prefer new least-privilege credential for Azure"
    },
    "firebase-client-email": {
      "envVars": ["FIREBASE_CLIENT_EMAIL"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Firebase service account client email",
      "rotation": "copy from the paired Firebase service account when using split credentials"
    },
    "firebase-private-key": {
      "envVars": ["FIREBASE_PRIVATE_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Firebase service account private key",
      "rotation": "rotate with the paired Firebase service account credential"
    },
    "auth-vault-secret": {
      "envVars": ["AUTH_VAULT_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "preserve current value for first Azure deploy, rotate later with AUTH_VAULT_PREVIOUS_SECRETS"
    },
    "auth-vault-previous-secrets": {
      "envVars": ["AUTH_VAULT_PREVIOUS_SECRETS"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret history",
      "rotation": "store only during staged auth-vault rotations"
    },
    "auth-device-challenge-secret": {
      "envVars": ["AUTH_DEVICE_CHALLENGE_SECRET"],
      "consumers": ["api"],
      "sourceOfTruth": "internal secret",
      "rotation": "rotate independently from AUTH_VAULT_SECRET when trusted-device mode is enabled"
    },
    "auth-device-challenge-previous-secrets": {
      "envVars": ["AUTH_DEVICE_CHALLENGE_PREVIOUS_SECRETS"],
      "consumers": ["api"],
      "sourceOfTruth": "internal secret history",
      "rotation": "store only during staged trusted-device secret rotations"
    },
    "upload-signing-secret": {
      "envVars": ["UPLOAD_SIGNING_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "otp-flow-secret": {
      "envVars": ["OTP_FLOW_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "otp-challenge-secret": {
      "envVars": ["OTP_CHALLENGE_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "cron-secret": {
      "envVars": ["CRON_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    },
    "metrics-secret": {
      "envVars": ["METRICS_SECRET"],
      "consumers": ["api"],
      "sourceOfTruth": "internal secret",
      "rotation": "generate fresh in Azure"
    }
  },
  "payments": {
    "razorpay-key-id": {
      "envVars": ["RAZORPAY_KEY_ID"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Razorpay dashboard",
      "rotation": "copy from provider, rotate after cutover if desired"
    },
    "razorpay-key-secret": {
      "envVars": ["RAZORPAY_KEY_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Razorpay dashboard",
      "rotation": "copy from provider, rotate after cutover if desired"
    },
    "razorpay-webhook-secret": {
      "envVars": ["RAZORPAY_WEBHOOK_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Razorpay dashboard",
      "rotation": "set new secret if webhook endpoint changes"
    }
  },
  "communications": {
    "resend-api-key": {
      "envVars": ["RESEND_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Resend dashboard",
      "rotation": "copy from provider"
    },
    "resend-webhook-secret": {
      "envVars": ["RESEND_WEBHOOK_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Resend webhook signing secret",
      "rotation": "set from the configured Resend webhook endpoint"
    },
    "gmail-app-password": {
      "envVars": ["GMAIL_APP_PASSWORD"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Google account",
      "rotation": "prefer migrating to Resend instead"
    },
    "twilio-account-sid": {
      "envVars": ["TWILIO_ACCOUNT_SID"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Twilio console",
      "rotation": "copy from provider"
    },
    "twilio-auth-token": {
      "envVars": ["TWILIO_AUTH_TOKEN"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Twilio console",
      "rotation": "copy from provider or regenerate if rotating"
    },
    "twilio-from-number": {
      "envVars": ["TWILIO_FROM_NUMBER"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Twilio console",
      "rotation": "copy from provider"
    },
    "twilio-whatsapp-from": {
      "envVars": ["TWILIO_WHATSAPP_FROM"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Twilio console",
      "rotation": "copy from provider when WhatsApp delivery is enabled"
    }
  },
  "ai": {
    "gemini-api-key": {
      "envVars": ["GEMINI_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Google AI Studio / Gemini API",
      "rotation": "copy from provider and rotate in Google first"
    },
    "groq-api-key": {
      "envVars": ["GROQ_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Groq dashboard",
      "rotation": "optional voice / fallback provider only"
    },
    "voyage-api-key": {
      "envVars": ["VOYAGE_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "Voyage dashboard",
      "rotation": "optional rerank / voice-adjacent provider only"
    },
    "elevenlabs-api-key": {
      "envVars": ["ELEVENLABS_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "ElevenLabs dashboard",
      "rotation": "copy from provider"
    },
    "livekit-api-key": {
      "envVars": ["LIVEKIT_API_KEY"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "LiveKit dashboard",
      "rotation": "copy from provider"
    },
    "livekit-api-secret": {
      "envVars": ["LIVEKIT_API_SECRET"],
      "consumers": ["api", "worker"],
      "sourceOfTruth": "LiveKit dashboard",
      "rotation": "copy from provider"
    },
    "ai-internal-auth-secret": {
      "envVars": ["AI_INTERNAL_AUTH_SECRET"],
      "consumers": ["api"],
      "sourceOfTruth": "internal signing secret",
      "rotation": "rotate with AI_INTERNAL_AUTH_PREVIOUS_SECRETS during staged internal service token key changes"
    },
    "ai-internal-auth-previous-secrets": {
      "envVars": ["AI_INTERNAL_AUTH_PREVIOUS_SECRETS"],
      "consumers": ["api"],
      "sourceOfTruth": "internal signing secret history",
      "rotation": "store only during staged internal service token key rotations"
    },
    "ai-internal-tool-secret": {
      "envVars": ["AI_INTERNAL_TOOL_SECRET"],
      "consumers": ["api"],
      "sourceOfTruth": "internal secret",
      "rotation": "set a dedicated secret for internal AI-to-backend calls instead of reusing CRON_SECRET"
    }
  }
}
