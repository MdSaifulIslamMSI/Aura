{
  "services": [
    {
      "key": "api",
      "templatePath": "infra/azure/server-api.appsettings.example.env",
      "imageRefParameter": "ApiImageRef",
      "ingress": "external",
      "targetPort": 8080,
      "transport": "auto",
      "cpu": "1.0",
      "memory": "2.0Gi",
      "minReplicas": 1,
      "maxReplicas": 3,
      "revisionsMode": "single"
    },
    {
      "key": "worker",
      "templatePath": "infra/azure/server-worker.appsettings.example.env",
      "imageRefParameter": "WorkerImageRef",
      "cpu": "1.0",
      "memory": "2.0Gi",
      "minReplicas": 1,
      "maxReplicas": 1,
      "revisionsMode": "single",
      "command": ["node", "scripts/start_worker_runtime.js"]
    }
  ]
}
