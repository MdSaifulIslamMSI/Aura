{
  "family": "aura-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "__ECS_TASK_EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__ECS_TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "aura-api",
      "image": "__AWS_ACCOUNT_ID__.dkr.ecr.__AWS_REGION__.amazonaws.com/__AWS_ECR_REPOSITORY__:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "5000" },
        { "name": "CORS_ORIGIN", "value": "__FRONTEND_ORIGIN__" },
        { "name": "APP_PUBLIC_URL", "value": "__APP_PUBLIC_URL__" },
        { "name": "REDIS_ENABLED", "value": "true" },
        { "name": "REDIS_REQUIRED", "value": "true" },
        { "name": "SPLIT_RUNTIME_ENABLED", "value": "true" },
        { "name": "UPLOAD_STORAGE_DRIVER", "value": "s3" },
        { "name": "AWS_REGION", "value": "__AWS_REGION__" },
        { "name": "REVIEW_UPLOAD_S3_BUCKET", "value": "__REVIEW_UPLOAD_S3_BUCKET__" },
        { "name": "REVIEW_UPLOAD_S3_PREFIX", "value": "__REVIEW_UPLOAD_S3_PREFIX__" },
        { "name": "REVIEW_UPLOAD_PUBLIC_BASE_URL", "value": "__REVIEW_UPLOAD_PUBLIC_BASE_URL__" }
      ],
      "secrets": [
        {
          "name": "MONGO_URI",
          "valueFrom": "__MONGO_URI_SECRET_ARN__"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "__REDIS_URL_SECRET_ARN__"
        },
        {
          "name": "BYTEZ_API_KEY",
          "valueFrom": "__BYTEZ_API_KEY_SECRET_ARN__"
        },
        {
          "name": "UPLOAD_SIGNING_SECRET",
          "valueFrom": "__UPLOAD_SIGNING_SECRET_SECRET_ARN__"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aura-api",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"fetch('http://127.0.0.1:5000/health/ready').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
