{
  "name": "aura-marketplace-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop wrapper for Aura Marketplace",
  "author": "MdSaifulIslamMSI <MdSaifulIslamMSI@users.noreply.github.com>",
  "main": "desktop/main.cjs",
  "scripts": {
    "build": "cd app && npm install && npm run build",
    "aws:ssm:sync": "powershell -ExecutionPolicy Bypass -File .\\infra\\aws\\sync-parameter-store-env.ps1 -SourceEnvFile .\\server\\.env.aws-secrets",
    "backend:origin": "node .\\app\\scripts\\print_hosted_backend_origin.mjs",
    "vercel:routing:sync": "node .\\app\\scripts\\sync_vercel_configs.mjs",
    "dev:on": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev-on.ps1",
    "dev:off": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev-off.ps1",
    "dev:off:force": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev-off.ps1 -ForceKill",
    "codex:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\codex-restart.ps1",
    "codex:open": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\codex-open.ps1",
    "desktop:frontend:build": "npm --prefix app run build",
    "desktop:start": "npm run desktop:frontend:build && electron .",
    "desktop:pack": "npm run desktop:frontend:build && electron-builder --dir",
    "desktop:dist": "npm run desktop:dist:win",
    "desktop:dist:win": "npm run desktop:frontend:build && electron-builder --win nsis portable --x64",
    "desktop:dist:win:all": "npm run desktop:frontend:build && electron-builder --win nsis portable --x64 --ia32 --arm64",
    "desktop:dist:mac": "npm run desktop:frontend:build && electron-builder --mac dmg zip --x64 --arm64",
    "desktop:dist:linux": "npm run desktop:frontend:build && electron-builder --linux AppImage deb rpm tar.gz --x64 --arm64",
    "desktop:dist:portable": "npm run desktop:frontend:build && electron-builder --win portable --x64",
    "security:deprecated": "node scripts/check-lockfile-deprecations.js",
    "security:audit:root": "npm audit --omit=dev --audit-level=low",
    "security:audit:app": "npm --prefix app audit --omit=dev --audit-level=low",
    "security:audit:server": "npm --prefix server audit --omit=dev --audit-level=low",
    "security:audit": "npm run security:audit:root && npm run security:audit:app && npm run security:audit:server",
    "security:prod-env-audit": "node server/scripts/audit_login_production_env_contract.js",
    "security:prod-live-smoke": "node scripts/smoke-production-login.mjs",
    "security:attack-smoke": "npm --prefix server test -- --runTestsByPath tests/loginAttackSmoke.test.js",
    "security:auth-tests": "npm --prefix server test -- --runTestsByPath tests/authRoutes.integration.test.js tests/otpRoutes.test.js tests/authMiddleware.cookie.test.js tests/browserSessionService.test.js tests/trustedDeviceChallengeService.test.js tests/authSessionService.test.js tests/csrfMiddleware.test.js tests/distributedRateLimit.test.js tests/authRecoveryCodeService.test.js tests/authMiddleware.admin.test.js",
    "security:login-gates": "npm run security:deprecated && npm run security:audit && npm run security:prod-env-audit && npm run security:attack-smoke && npm run security:auth-tests",
    "mobile:doctor": "npm --prefix app run mobile:doctor",
    "mobile:sync": "npm --prefix app run mobile:sync",
    "mobile:sync:android": "npm --prefix app run mobile:sync:android",
    "mobile:sync:ios": "npm --prefix app run mobile:sync:ios"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5"
  },
  "devDependencies": {
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^5.0.0",
    "@electron/rebuild": "^4.0.4",
    "cacache": "^20.0.4",
    "glob": "^13.0.6",
    "lodash.isequal": "npm:fast-deep-equal@^3.1.3",
    "make-fetch-happen": "^15.0.5",
    "node-gyp": "^12.3.0",
    "rimraf": "^6.1.3"
  },
  "build": {
    "appId": "com.aura.marketplace.desktop",
    "productName": "Aura Marketplace",
    "asar": true,
    "directories": {
      "app": ".",
      "output": "desktop-release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MdSaifulIslamMSI",
        "repo": "Aura",
        "releaseType": "release"
      }
    ],
    "files": [
      "desktop/**/*",
      "package.json",
      "!app/**/*",
      "!docs/**/*",
      "!gateway/**/*",
      "!generated/**/*",
      "!infra/**/*",
      "!server/**/*",
      "!.github/**/*",
      "!**/*.log",
      "!**/.env*"
    ],
    "extraResources": [
      {
        "from": "app/dist",
        "to": "app-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "app/public/assets/icon-512.png",
        "to": "app-icon.png"
      }
    ],
    "win": {
      "icon": "app/public/assets/icon-512.png",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "category": "public.app-category.shopping",
      "icon": "app/public/assets/icon-512.png",
      "extendInfo": {
        "NSCameraUsageDescription": "Aura Marketplace uses the camera for live marketplace and support video calls.",
        "NSMicrophoneUsageDescription": "Aura Marketplace uses the microphone for live marketplace and support voice or video calls."
      },
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Aura-Marketplace-macOS-${arch}.${ext}"
    },
    "linux": {
      "category": "Office",
      "icon": "app/public/assets/icon-512.png",
      "maintainer": "MdSaifulIslamMSI <MdSaifulIslamMSI@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ],
      "artifactName": "Aura-Marketplace-Linux-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Aura-Marketplace-Windows-${arch}-Portable.${ext}"
    },
    "appImage": {
      "artifactName": "Aura-Marketplace-Linux-${arch}.AppImage"
    },
    "deb": {
      "artifactName": "Aura-Marketplace-Linux-${arch}.deb"
    },
    "rpm": {
      "artifactName": "Aura-Marketplace-Linux-${arch}.rpm"
    },
    "nsis": {
      "artifactName": "Aura-Marketplace-Windows-${arch}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": "desktop/assets/installer-sidebar.bmp",
      "uninstallerSidebar": "desktop/assets/installer-sidebar.bmp",
      "installerHeader": "desktop/assets/installer-header.bmp",
      "shortcutName": "Aura Marketplace"
    },
    "dmg": {
      "artifactName": "Aura-Marketplace-macOS-${arch}.dmg",
      "background": "desktop/assets/dmg-background.png",
      "window": {
        "width": 660,
        "height": 420
      },
      "contents": [
        {
          "x": 185,
          "y": 205,
          "type": "file"
        },
        {
          "x": 475,
          "y": 205,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
