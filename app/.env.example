VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_DISABLE_SOCIAL_AUTH=false
VITE_API_URL=http://127.0.0.1:5000/api
VITE_ENABLE_REALTIME_SOCKET=true
VITE_PERSIST_TRUSTED_DEVICE_SESSION=false
VITE_VERCEL_FRONTEND_URL=https://your-vercel-frontend-url.vercel.app
VITE_NETLIFY_FRONTEND_URL=https://your-netlify-frontend-url.netlify.app

# live payment provider
VITE_PAYMENT_PROVIDER=razorpay

# smooth scroll engine toggle (true/false)
VITE_LENIS_ENABLED=true
