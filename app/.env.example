VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_DISABLE_SOCIAL_AUTH=false
VITE_FIREBASE_ENABLE_MICROSOFT_AUTH=false
VITE_FIREBASE_ENABLE_APPLE_AUTH=false
VITE_DUO_LOGIN_ENABLED=false
VITE_MOBILE_NATIVE_SOCIAL_AUTH_ENABLED=false
VITE_MOBILE_FIREBASE_PHONE_OTP_ENABLED=false
VITE_API_URL=http://127.0.0.1:5000/api
VITE_API_URL_ALLOW_CROSS_ORIGIN_HOSTED=false
VITE_TURNSTILE_SITE_KEY=example-turnstile-site-key
VITE_ENABLE_REALTIME_SOCKET=true
VITE_PERSIST_TRUSTED_DEVICE_SESSION=false
VITE_AUTH_SHIELD_DPOP_ENABLED=false
VITE_ALIEN_OTP_ENABLED=false
VITE_VERCEL_FRONTEND_URL=https://your-vercel-frontend-url.vercel.app
VITE_NETLIFY_FRONTEND_URL=https://your-netlify-frontend-url.netlify.app
VITE_WELCOME_CURTAIN_ENABLED=true
VITE_WELCOME_CURTAIN_SOUND_ENABLED=true
VITE_ADMIN_SECURITY_STATE_ENGINE_V2=false

# live payment provider
VITE_PAYMENT_PROVIDER=razorpay

# smooth scroll engine toggle (true/false)
VITE_LENIS_ENABLED=true
