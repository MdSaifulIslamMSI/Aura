VITE_API_URL=/api
VITE_FIREBASE_API_KEY=example
VITE_FIREBASE_AUTH_DOMAIN=example.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=example-project
VITE_FIREBASE_STORAGE_BUCKET=example-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:example
VITE_FIREBASE_MEASUREMENT_ID=G-EXAMPLE
VITE_FIREBASE_DISABLE_SOCIAL_AUTH=false
VITE_FIREBASE_ENABLE_MICROSOFT_AUTH=true
VITE_FIREBASE_ENABLE_APPLE_AUTH=false
VITE_MOBILE_NATIVE_SOCIAL_AUTH_ENABLED=false
VITE_MOBILE_FIREBASE_PHONE_OTP_ENABLED=false
VITE_VERCEL_FRONTEND_URL=https://example.vercel.app
VITE_NETLIFY_FRONTEND_URL=https://example.netlify.app
VITE_WELCOME_CURTAIN_ENABLED=true
VITE_WELCOME_CURTAIN_SOUND_ENABLED=true
