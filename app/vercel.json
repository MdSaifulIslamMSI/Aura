{
    "rewrites": [
        {
            "source": "/socket.io",
            "destination": "http://3.109.181.238:5000/socket.io"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "http://3.109.181.238:5000/socket.io/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "http://3.109.181.238:5000/api/:path*"
        },
        {
            "source": "/health",
            "destination": "http://3.109.181.238:5000/health"
        },
        {
            "source": "/health/ready",
            "destination": "http://3.109.181.238:5000/health/ready"
        },
        {
            "source": "/health/live",
            "destination": "http://3.109.181.238:5000/health/live"
        },
        {
            "source": "/uploads/:path*",
            "destination": "http://3.109.181.238:5000/uploads/:path*"
        },
        {
            "source": "/:path((?!api/|socket\\.io(?:/|$)|uploads/|assets/|manifest\\.json$|sw\\.js$|favicon\\.ico$|robots\\.txt$|.*\\.[^/]+$).*)",
            "destination": "/index.html"
        }
    ]
}
