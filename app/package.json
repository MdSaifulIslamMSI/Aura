{
  "name": "flipkart-clone",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:budget": "npm run build && node scripts/check_bundle_budget.mjs",
    "bundle:budget": "node scripts/check_bundle_budget.mjs",
    "backend:origin": "node scripts/print_hosted_backend_origin.mjs",
    "vercel:routing:sync": "node scripts/sync_vercel_configs.mjs",
    "audit:locale": "node scripts/check_locale_coverage.mjs",
    "bench:mobile": "node scripts/mobile_benchmark.mjs",
    "i18n:generate": "node scripts/generate_market_messages.mjs && node scripts/generate_market_message_packs.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:locale": "node scripts/run_locale_visual_qa.mjs",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.8.0",
    "framer-motion": "^12.36.0",
    "lenis": "^1.3.18-dev.1",
    "livekit-client": "^2.18.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
