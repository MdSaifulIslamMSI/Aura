{
  "name": "flipkart-clone",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/validate_frontend_auth_env.mjs",
    "dev": "vite",
    "build": "vite build",
    "build:budget": "npm run build && node scripts/check_bundle_budget.mjs",
    "bundle:budget": "node scripts/check_bundle_budget.mjs",
    "backend:doctor": "node scripts/check_backend_connectivity.mjs",
    "backend:origin": "node scripts/print_hosted_backend_origin.mjs",
    "vercel:routing:sync": "node scripts/sync_vercel_configs.mjs",
    "audit:locale": "node scripts/check_locale_coverage.mjs",
    "audit:locale:quality": "node scripts/check_locale_quality.mjs",
    "bench:mobile": "node scripts/mobile_benchmark.mjs",
    "i18n:generate": "node scripts/generate_market_messages.mjs && node scripts/generate_market_message_packs.mjs",
    "i18n:repair-native": "node scripts/generate_market_message_packs.mjs --languages=bn,hi,te,mr,ur,gu,pa,ml,kn,or,as,sa,ar,ja,zh",
    "i18n:extract": "formatjs extract \"src/**/*.{js,jsx,ts,tsx}\" --out-file src/i18n/messages/source/en.json --throws",
    "i18n:compile": "node scripts/i18n/compile-formatjs-messages.mjs",
    "i18n:verify": "formatjs verify \"src/i18n/messages/reviewed/*.json\" --source-locale en --missing-keys --structural-equality",
    "i18n:pseudo": "node scripts/i18n/generate-pseudo-locale.mjs",
    "i18n:qa": "node scripts/i18n/locale-qa.mjs",
    "i18n:check": "npm run i18n:extract && npm run i18n:pseudo && npm run i18n:compile && npm run i18n:verify && npm run i18n:qa",
    "lint": "eslint .",
    "mobile:doctor": "npx cap doctor",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:sync:android": "npm run build && npx cap sync android",
    "mobile:sync:ios": "npm run build && npx cap sync ios",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:locale": "node scripts/run_locale_visual_qa.mjs",
    "test:e2e:locale:a11y": "node scripts/run_locale_accessibility_qa.mjs",
    "test:e2e:ui": "playwright test --ui",
    "lambdatest:tunnel": "node scripts/lambdatest_tunnel.mjs",
    "lambdatest:playwright": "playwright-node-sdk playwright test"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor/app": "^8.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.16.0",
    "framer-motion": "^12.40.0",
    "lenis": "^1.3.23",
    "livekit-client": "^2.18.8",
    "lucide-react": "^0.562.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-intl": "^10.1.11",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@eslint/js": "^9.39.1",
    "@formatjs/cli": "^6.16.6",
    "@formatjs/icu-messageformat-parser": "^3.5.10",
    "@lambdatest/node-tunnel": "^4.0.11",
    "@lambdatest/playwright-node-sdk": "^1.0.2",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-formatjs": "^6.4.13",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "jsdom": {
      "undici": "7.28.0"
    },
    "rollup": "4.59.1",
    "ws": "^8.20.1"
  }
}
