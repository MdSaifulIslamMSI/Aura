{
  "scanRoots": [
    "app/src",
    "app/index.html",
    "app/public",
    "server/services/email",
    "server/templates",
    "server/emails",
    "server/notifications"
  ],
  "extensions": [
    ".js",
    ".jsx",
    ".ts",
    ".tsx",
    ".html",
    ".json"
  ],
  "skipDirectories": [
    ".git",
    ".next",
    ".turbo",
    ".vercel",
    "build",
    "coverage",
    "desktop-release",
    "dist",
    "generated",
    "node_modules",
    "output",
    "playwright-report",
    "test-results"
  ],
  "skipPathIncludes": [
    "app/src/i18n/messages/compiled/",
    "app/src/i18n/messages/reviewed/",
    "app/src/i18n/messages/source/",
    "app/src/i18n/messages/stableUiMessages.js",
    "app/src/i18n/quality/humanReviewQueue.json",
    "app/src/i18n/quality/nativeReviewAudit.json",
    "app/src/config/marketMessages.generated",
    "app/src/config/marketMessagePacks",
    "coverage/",
    "__snapshots__/",
    ".snap"
  ],
  "jsonUiPathIncludes": [
    "manifest",
    "metadata",
    "navigation",
    "onboarding",
    "app/src/i18n/quality"
  ],
  "userVisibleProps": [
    "placeholder",
    "aria-label",
    "aria-description",
    "aria-roledescription",
    "alt",
    "title",
    "label",
    "helperText",
    "errorText",
    "successText",
    "emptyText",
    "noResultsText",
    "tooltip",
    "description",
    "subtitle",
    "heading",
    "buttonText",
    "cta",
    "confirmText",
    "cancelText",
    "closeLabel",
    "submitLabel",
    "loadingText",
    "children"
  ],
  "objectUiKeys": [
    "label",
    "title",
    "name",
    "description",
    "subtitle",
    "heading",
    "text",
    "cta",
    "button",
    "buttonText",
    "emptyMessage",
    "emptyText",
    "tooltip",
    "badge",
    "status",
    "tab",
    "menu",
    "nav",
    "columnHeader",
    "headerName",
    "placeholder",
    "helperText",
    "errorText",
    "successText",
    "message",
    "summary",
    "eyebrow"
  ],
  "toastFunctionNames": [
    "alert",
    "confirm",
    "enqueueSnackbar",
    "notify",
    "prompt",
    "showToast"
  ],
  "toastObjectNames": [
    "toast",
    "snackbar",
    "notification"
  ],
  "toastMethodNames": [
    "custom",
    "error",
    "info",
    "loading",
    "message",
    "success",
    "warning"
  ],
  "validationFunctionNames": [
    "setError",
    "setFieldError"
  ],
  "validationPropertyNames": [
    "invalid_type_error",
    "message",
    "required_error"
  ],
  "highRiskKeywords": [
    "account deletion",
    "admin destructive",
    "cancel order",
    "checkout",
    "consent",
    "delete account",
    "otp",
    "passkey",
    "payment",
    "payout",
    "refund",
    "return",
    "security",
    "trusted device"
  ],
  "highRiskPathIncludes": [
    "/Admin/",
    "/Checkout",
    "/Login",
    "/Payment",
    "/Refund",
    "/Return",
    "/Seller",
    "/Support",
    "/auth",
    "/checkout",
    "/payment",
    "/refund",
    "/seller",
    "/support"
  ],
  "mediumRiskKeywords": [
    "cart",
    "delivery",
    "filter",
    "inventory",
    "notification",
    "profile",
    "search",
    "settings",
    "wishlist"
  ],
  "mediumRiskPathIncludes": [
    "/Cart",
    "/Discovery",
    "/Orders",
    "/Product",
    "/Profile",
    "/Wishlist",
    "/cart",
    "/discovery",
    "/orders",
    "/product",
    "/profile",
    "/wishlist"
  ],
  "dynamicPathIncludes": [
    "/data/",
    "/fixtures/",
    "/seed",
    "/seeders/",
    "/mock",
    "/catalog/",
    "catalogTaxonomy",
    "marketplaceListings",
    "demo_catalog",
    "kaggle"
  ],
  "developerOnlyPathIncludes": [
    "/scripts/",
    "/tests/",
    ".test.",
    ".spec.",
    "setupTests",
    "test-utils"
  ],
  "maxFalsePositiveEntries": 1000
}
