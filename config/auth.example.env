# Aura authentication contract. Copy values into a local, untracked env file.
# Do not commit real client secrets, realm signing keys, passwords, or tokens.

# Rollback-safe default. Set to keycloak only after local or staging validation passes.
AUTH_PROVIDER=legacy

# Keycloak/OIDC client configuration.
AUTH_ISSUER_URL=http://localhost:8080/realms/aura-dev
AUTH_CLIENT_ID=aura-web
AUTH_CLIENT_TYPE=public
AUTH_CLIENT_SECRET=
AUTH_OIDC_STATE_SECRET=replace-with-local-only-state-signing-secret
AUTH_AUDIENCE=aura-web
AUTH_JWKS_URL=http://localhost:8080/realms/aura-dev/protocol/openid-connect/certs
AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
AUTH_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login

# Session and security policy.
AUTH_COOKIE_NAME=aura_sid
AUTH_REQUIRE_MFA_FOR_ADMIN=true
AUTH_ALLOWED_CLOCK_SKEW_SECONDS=60
AUTH_RATE_LIMIT_LOGIN=10
AUTH_RATE_LIMIT_PASSWORD_RESET=5
AUTH_RATE_LIMIT_SIGNUP=5
AUTH_RATE_LIMIT_TOKEN_REFRESH=30
AUTH_RATE_LIMIT_MFA_CHALLENGE=10

# Local-only Keycloak container bootstrap. Replace locally, never in Git.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-local-only-admin-password
KEYCLOAK_DB_PASSWORD=replace-with-local-only-db-password
