# Example-only production contract. Replace through your secret manager or CI/CD environment.
APP_ENV=production
NODE_ENV=production
PORT=5000
APP_BASE_URL=https://www.example.invalid
API_BASE_URL=https://api.example.invalid
DATABASE_URL=mongodb://prod-db.example.invalid:27017/aura?tls=true&retryWrites=true&w=majority
MONGO_URI=mongodb://prod-db.example.invalid:27017/aura?tls=true&retryWrites=true&w=majority
MONGO_REQUIRE_TLS=true
MONGO_REQUIRE_REPLICA_SET=true
MONGO_AUTO_INDEX=false
REDIS_URL=rediss://prod-redis.example.invalid:6379
OBJECT_STORAGE_BUCKET=aura-production-uploads-example
OTEL_SERVICE_NAME=aura-marketplace-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.invalid
LOG_LEVEL=info
CORS_ORIGINS=https://www.example.invalid
HEALTHCHECK_PATH=/health
MFA_ENABLED=false
MFA_TOTP_ENABLED=false
MFA_PASSKEY_ENABLED=false
MFA_RECOVERY_CODES_ENABLED=true
MFA_REQUIRED_FOR_ADMINS=false
MFA_REQUIRED_FOR_SELLERS=false
MFA_CHALLENGE_TTL_SECONDS=300
MFA_FRESH_WINDOW_SECONDS=900
AUTH_SHIELD_ENABLED=false
AUTH_SHIELD_SHADOW_MODE=true
AUTH_SHIELD_AUDIT_ENABLED=true
AUTH_SHIELD_REPLAY_GUARD_ENABLED=true
AUTH_SHIELD_DPOP_ENABLED=false
AUTH_SHIELD_DEVICE_TRUST_ENABLED=false
AUTH_SHIELD_STEP_UP_ENABLED=false
AUTH_SHIELD_RISK_ENGINE_ENABLED=true
AUTH_SHIELD_FAIL_CLOSED_ACTIONS=admin.*,payment.*,auth.mfa.*,auth.password.*,auth.email.*,auth.role.*,security.*
AUTH_SHIELD_STEP_UP_TTL_CRITICAL_SECONDS=300
AUTH_SHIELD_STEP_UP_TTL_HIGH_SECONDS=900
AUTH_SHIELD_REPLAY_TTL_SECONDS=300
AUTH_SHIELD_POLICY_VERSION=2026-06-05
ALIEN_OTP_ENABLED=false
ALIEN_OTP_LOGIN_ENABLED=false
ALIEN_OTP_SENSITIVE_ACTIONS_ENABLED=false
ALIEN_OTP_DEVICE_BOUND_ENABLED=false
ALIEN_OTP_DPOP_COMPAT_ENABLED=false
ALIEN_OTP_RISK_ENGINE_ENABLED=false
ALIEN_OTP_STRICT_MODE=false
ALIEN_OTP_AUDIT_ENABLED=true
ALIEN_OTP_CHALLENGE_TTL_SECONDS=60
ALIEN_OTP_MAX_FAILURES_PER_WINDOW=5
STAGING_BASE_URL=https://staging.example.invalid
STAGING_API_BASE_URL=https://api.staging.example.invalid
STAGING_HEALTH_URL=https://api.staging.example.invalid/health
PROD_BASE_URL=https://www.example.invalid
PROD_API_BASE_URL=https://api.example.invalid
PROD_HEALTH_URL=https://api.example.invalid/health
I18N_RUNTIME_TRANSLATION_ENABLED=false
I18N_TRANSLATION_PROVIDER=noop
I18N_TRANSLATION_CACHE_ENABLED=true
I18N_TRANSLATION_REQUIRE_AUTH_FOR_HEAVY_USAGE=true

# Invisible App Fabric is enabled in production. Trusted edge mode requires
# a CDN/WAF/reverse proxy to inject INVISIBLE_TRUSTED_EDGE_HEADER.
INVISIBLE_FABRIC_ENABLED=true
INVISIBLE_REQUIRE_TRUSTED_EDGE=false
INVISIBLE_TRUSTED_EDGE_HEADER=x-aura-edge-secret
INVISIBLE_TRUSTED_EDGE_SECRET=
INVISIBLE_CLOAK_ADMIN=true
INVISIBLE_CLOAK_INTERNAL_ROUTES=true
INVISIBLE_BLOCK_PROD_DEBUG=true
INVISIBLE_ROUTE_CLASSIFICATION_REQUIRED=true
INVISIBLE_HONEYPOTS_ENABLED=true
INVISIBLE_REPLAY_GUARD_ENABLED=true
INVISIBLE_RESPONSE_MINIMIZATION=true
INVISIBLE_PUBLIC_ROUTE_MANIFEST_REQUIRED=true
INVISIBLE_AUDIT_ENABLED=true
