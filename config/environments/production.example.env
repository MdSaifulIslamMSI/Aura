# Example-only production contract. Replace through your secret manager or CI/CD environment.
APP_ENV=production
NODE_ENV=production
PORT=5000
APP_BASE_URL=https://www.example.invalid
API_BASE_URL=https://api.example.invalid
DATABASE_URL=mongodb://prod-db.example.invalid:27017/aura
MONGO_URI=mongodb://prod-db.example.invalid:27017/aura
REDIS_URL=rediss://prod-redis.example.invalid:6379
OBJECT_STORAGE_BUCKET=aura-production-uploads-example
OTEL_SERVICE_NAME=aura-marketplace-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.invalid
LOG_LEVEL=info
CORS_ORIGINS=https://www.example.invalid
HEALTHCHECK_PATH=/health
MFA_ENABLED=false
MFA_TOTP_ENABLED=false
MFA_PASSKEY_ENABLED=false
MFA_RECOVERY_CODES_ENABLED=true
MFA_REQUIRED_FOR_ADMINS=false
MFA_REQUIRED_FOR_SELLERS=false
MFA_EMAIL_OTP_FALLBACK_ENABLED=false
MFA_CHALLENGE_TTL_SECONDS=300
MFA_FRESH_WINDOW_SECONDS=900
STAGING_BASE_URL=https://staging.example.invalid
STAGING_API_BASE_URL=https://api.staging.example.invalid
STAGING_HEALTH_URL=https://api.staging.example.invalid/health
PROD_BASE_URL=https://www.example.invalid
PROD_API_BASE_URL=https://api.example.invalid
PROD_HEALTH_URL=https://api.example.invalid/health
I18N_RUNTIME_TRANSLATION_ENABLED=false
I18N_TRANSLATION_PROVIDER=noop
I18N_TRANSLATION_CACHE_ENABLED=true
I18N_TRANSLATION_REQUIRE_AUTH_FOR_HEAVY_USAGE=true
