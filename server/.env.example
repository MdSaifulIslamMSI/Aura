NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/aura
CORS_ORIGIN=http://localhost:5173
AWS_FRONTEND_URL=http://your-bucket.s3-website.ap-south-1.amazonaws.com
JSON_BODY_LIMIT=12mb
UPLOAD_STORAGE_DRIVER=local
REVIEW_UPLOAD_MAX_BYTES=7340032
REVIEW_UPLOAD_DIR=
AWS_REGION=ap-south-1
AWS_S3_REVIEW_BUCKET=
AWS_S3_REVIEW_PREFIX=review-media
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
REDIS_ENABLED=false
REDIS_REQUIRED=false
SPLIT_RUNTIME_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=aura
REDIS_CONNECT_TIMEOUT_MS=3000
CRON_SECRET=replace-with-long-random-secret-for-internal-jobs
METRICS_SECRET=replace-with-long-random-secret-for-metrics

# AWS Parameter Store runtime bootstrap (optional when instance roles or GitHub Actions populate secrets)
AWS_PARAMETER_STORE_ENABLED=false
AWS_PARAMETER_STORE_PATH_PREFIX=/aura/prod
AWS_PARAMETER_STORE_SECRET_KEYS=MONGO_URI,REDIS_URL,FIREBASE_SERVICE_ACCOUNT,FIREBASE_CLIENT_EMAIL,FIREBASE_PRIVATE_KEY,AUTH_VAULT_SECRET,AUTH_VAULT_PREVIOUS_SECRETS,AUTH_DEVICE_CHALLENGE_SECRET,AUTH_DEVICE_CHALLENGE_PREVIOUS_SECRETS,AUTH_RECOVERY_CODE_SECRET,UPLOAD_SIGNING_SECRET,OTP_FLOW_SECRET,OTP_CHALLENGE_SECRET,CRON_SECRET,METRICS_SECRET,RAZORPAY_KEY_ID,RAZORPAY_KEY_SECRET,RAZORPAY_WEBHOOK_SECRET,STRIPE_SECRET_KEY,STRIPE_WEBHOOK_SECRET,OPEN_EXCHANGE_RATES_APP_ID,RESEND_API_KEY,RESEND_WEBHOOK_SECRET,GMAIL_APP_PASSWORD,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_FROM_NUMBER,TWILIO_WHATSAPP_FROM,GEMINI_API_KEY,GROQ_API_KEY,VOYAGE_API_KEY,ELEVENLABS_API_KEY,LIVEKIT_API_KEY,LIVEKIT_API_SECRET,AI_INTERNAL_AUTH_SECRET,AI_INTERNAL_AUTH_PREVIOUS_SECRETS,AI_INTERNAL_TOOL_SECRET
AWS_PARAMETER_STORE_SECRET_MAP=

# Admin portal strict access fortress
# Production defaults require ADMIN_REQUIRE_2FA, ADMIN_REQUIRE_PASSKEY, and
# ADMIN_REQUIRE_ALLOWLIST when these flags are omitted. Keep
# ADMIN_ALLOWLIST_EMAILS populated before deploying with NODE_ENV=production.
ADMIN_STRICT_ACCESS_ENABLED=true
ADMIN_REQUIRE_EMAIL_VERIFIED=true
ADMIN_REQUIRE_FRESH_LOGIN_MINUTES=30
ADMIN_REQUIRE_2FA=true
ADMIN_REQUIRE_PASSKEY=true
ADMIN_REQUIRE_ALLOWLIST=false
ADMIN_ALLOWLIST_EMAILS=admin@gmail.com
ADMIN_ANALYTICS_MONITOR_ENABLED=true
ADMIN_ANALYTICS_MONITOR_INTERVAL_MS=300000
ADMIN_ANALYTICS_ALERT_DEDUPE_MINUTES=30
ADMIN_ANALYTICS_TIMEZONE=Asia/Kolkata
ADMIN_BI_MODE=hybrid
ADMIN_POWERBI_ENABLED=false
ADMIN_POWERBI_WORKSPACE_LABEL=Aura Executive BI
ADMIN_POWERBI_DASHBOARD_URL=

# Firebase Configuration (SECURITY: Use environment variables, not hardcoded)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OTP + email delivery (SECURITY: Store credentials in secure secrets manager, never in git)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Controlled commerce assistant model gateway
AI_MODEL_PROVIDER=gemini
AI_MODEL_PROVIDER_FALLBACKS=
ASSISTANT_COMMERCE_REQUIRE_HOSTED_GEMMA=true
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CHAT_MODEL=models/gemma-4-31b-it
GEMINI_CHAT_MODEL_FALLBACKS=models/gemma-4-26b-a4b-it
GEMINI_AUDIO_MODEL=models/gemma-3n-e4b-it
GEMINI_AUDIO_MODEL_FALLBACKS=models/gemma-3n-e2b-it
GEMINI_EMBED_MODEL=models/gemini-embedding-001
GEMINI_TIMEOUT_MS=45000
GEMINI_CHAT_MODEL_DEGRADE_MS=180000
ASSISTANT_QUERY_EMBED_CACHE_TTL_MS=1800000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gemma4:e4b
OLLAMA_CHAT_MODEL_FALLBACKS=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=120000
OLLAMA_KEEP_ALIVE=15m
AI_DEFAULT_LOCALE=en-IN
CHAT_PROVIDER_TIMEOUT_MS=8000
CHAT_USER_WINDOW_MS=900000
CHAT_USER_MAX_REQUESTS=60
CHAT_CIRCUIT_OPEN_MS=60000
CHAT_PROVIDER_MAX_FAILURES=5

# Optional realtime voice / speech providers
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_MODEL=openai/gpt-oss-20b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_AUDIO_MODEL=whisper-large-v3-turbo
GROQ_MODERATION_MODEL=openai/gpt-oss-safeguard-20b
GROQ_REQUEST_TIMEOUT_MS=12000
GROQ_RETRY_DELAY_MS=1000
GROQ_MAX_RETRIES=1
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_TEXT_EMBEDDING_MODEL=voyage-3.5-lite
VOYAGE_RERANK_MODEL=rerank-2.5-lite
VOYAGE_REQUEST_TIMEOUT_MS=12000
VOYAGE_RETRY_DELAY_MS=900
VOYAGE_MAX_RETRIES=1
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_REQUEST_TIMEOUT_MS=15000
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TTL_SECONDS=600
LIVEKIT_SUPPORT_ROOM_PREFIX=aura-support
LIVEKIT_LISTING_ROOM_PREFIX=aura-listing
# Internal AI service-to-service auth
AI_INTERNAL_AUTH_ACTIVE_KID=ai-v1
AI_INTERNAL_AUTH_SECRET=
# Comma-separated list, each entry as "<kid>:<secret>" for rotation.
AI_INTERNAL_AUTH_PREVIOUS_SECRETS=
AI_INTERNAL_AUTH_ISSUER=aura-internal-ai
AI_INTERNAL_AUTH_AUDIENCE=aura-api
AI_INTERNAL_AUTH_TOKEN_TTL_SECONDS=300
AI_INTERNAL_AUTH_CLOCK_SKEW_SECONDS=30
AI_INTERNAL_AUTH_ALLOW_LEGACY_SECRET=false
# Legacy migration fallback only. Leave blank once all callers use signed service tokens.
AI_INTERNAL_TOOL_SECRET=
# For self-hosted LiveKit, point LIVEKIT_URL at your public ws/wss endpoint.
# LiveKit's self-hosted deployment already includes TURN support, so a separate coturn box
# is only needed if you want TURN shared outside LiveKit traffic.

APP_BUILD_SHA=

# Payment Fortress flags
PAYMENTS_ENABLED=true
PAYMENT_PROVIDER=razorpay
PAYMENT_RISK_MODE=shadow
PAYMENT_CAPTURE_MODE=post_order_auth_capture
PAYMENT_SAVED_METHODS_ENABLED=true
PAYMENT_REFUNDS_ENABLED=true
PAYMENT_CHALLENGE_ENABLED=true
PAYMENT_FORTRESS_MAX_ACTIVE_INTENTS=6
PAYMENT_FORTRESS_MAX_CONFIRM_ATTEMPTS=12
PAYMENT_FORTRESS_MAX_CONFIRM_FAILURES=5
PAYMENT_FORTRESS_CONFIRM_LOCK_MINUTES=15

# FX provider stack
# auto: use Open Exchange Rates when OPEN_EXCHANGE_RATES_APP_ID is configured, else fall back to ECB daily rates
# openexchangerates: prefer real-time/latest JSON feed, then fall back to ECB if unavailable
# ecb: use ECB reference rates only
PAYMENT_FX_PROVIDER=auto
# Override cache lifetime if your FX plan supports a faster cadence. Defaults are provider-aware.
PAYMENT_FX_RATES_TTL_MS=
# Hourly scheduler for the backend-controlled FX pipeline.
PAYMENT_FX_SCHEDULER_ENABLED=true
PAYMENT_FX_BOOTSTRAP_ENABLED=true
PAYMENT_FX_REFRESH_CRON=0 * * * *
PAYMENT_FX_REFRESH_INTERVAL_MS=3600000
PAYMENT_FX_REFRESH_RETRY_ATTEMPTS=3
PAYMENT_FX_REFRESH_RETRY_BASE_DELAY_MS=1000
PAYMENT_FX_REFRESH_LOCK_TTL_MS=300000
PAYMENT_FX_HTTP_TIMEOUT_MS=10000
# Protect free-tier limits for rate-limited providers such as Open Exchange Rates.
PAYMENT_FX_MAX_CALLS_PER_DAY=24
PAYMENT_FX_SCHEDULER_TIMEZONE=UTC
OPEN_EXCHANGE_RATES_APP_ID=

# Razorpay (required when PAYMENT_PROVIDER=razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxx

# Stripe (required when PAYMENT_PROVIDER=stripe or PAYMENT_STRIPE_ROUTING_ENABLED=true)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# OTP challenge token signing
OTP_CHALLENGE_SECRET=replace-with-long-random-secret
FIREBASE_WEB_API_KEY=

# OTP Email Fortress V2
OTP_EMAIL_FAIL_CLOSED=true
OTP_EMAIL_CONTEXT_ENABLED=true
OTP_EMAIL_TTL_MINUTES=5
OTP_EMAIL_SEND_IN_TEST=false
OTP_LOGIN_REQUIRE_CREDENTIAL_PROOF=true
OTP_LOGIN_AUTO_RECOVER_PROFILE=false
AUTH_REQUIRE_INTERNATIONAL_PHONE_FORMAT=true
AUTH_VAULT_ENABLED=false
AUTH_VAULT_SECRET=replace-with-32-plus-char-random-secret
AUTH_VAULT_SECRET_VERSION=v1
# Comma-separated list, each entry as "<version>:<secret>" for key rotation
AUTH_VAULT_PREVIOUS_SECRETS=
AUTH_DEVICE_CHALLENGE_MODE=admin
AUTH_DEVICE_CHALLENGE_SECRET=
AUTH_DEVICE_CHALLENGE_SECRET_VERSION=v1
AUTH_DEVICE_CHALLENGE_PREVIOUS_SECRETS=
AUTH_DEVICE_CHALLENGE_ALLOW_VAULT_FALLBACK=true
AUTH_RECOVERY_CODE_SECRET=
AUTH_RECOVERY_CODE_SECRET_VERSION=v1
AUTH_TRUSTED_DEVICE_PREFER_WEBAUTHN=true
# Leave RP_ID and ORIGIN blank for host-derived local/dev behavior.
# Set both only when this API is fronted by one fixed production domain.
AUTH_WEBAUTHN_RP_NAME=Aura Trusted Device
AUTH_WEBAUTHN_RP_ID=
AUTH_WEBAUTHN_ORIGIN=
AUTH_WEBAUTHN_USER_VERIFICATION=required
AUTH_WEBAUTHN_TIMEOUT_MS=60000
AUTH_SESSION_COOKIE_NAME=aura_sid
AUTH_SESSION_IDLE_TTL_MS=28800000
AUTH_SESSION_ABSOLUTE_TTL_MS=604800000
AUTH_SESSION_SAME_SITE=lax
AUTH_SESSION_ADMIN_HOSTS=
UPLOAD_SIGNING_SECRET=replace-with-32-plus-char-random-secret
OTP_FLOW_SECRET=replace-with-32-plus-char-random-secret

# OTP SMS Fortress
OTP_SMS_ENABLED=true
OTP_SMS_PROVIDER=mock
OTP_SMS_FAIL_CLOSED=true
OTP_SMS_SEND_IN_TEST=false
OTP_WHATSAPP_ENABLED=false
OTP_SMS_TTL_MINUTES=5
OTP_SMS_DEFAULT_COUNTRY_CODE=+91
OTP_SMS_BRAND=AURA

# Twilio SMS provider (required in production when OTP_SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_STATUS_CALLBACK_URL=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Unified Email Gateway Fortress V3
EMAIL_FORTRESS_ENABLED=true
EMAIL_FORTRESS_STRICT_MODE=true
EMAIL_FORTRESS_ALLOWED_EVENT_TYPES=otp_security,order_placed,order_email_alert,user_activity,system
EMAIL_FORTRESS_ALLOW_HTML=true
EMAIL_FORTRESS_MAX_SUBJECT_LEN=140
EMAIL_FORTRESS_MAX_TEXT_LEN=20000
EMAIL_FORTRESS_MAX_HTML_LEN=250000

# Activity Email Fortress
ACTIVITY_EMAILS_ENABLED=true
ACTIVITY_EMAIL_COOLDOWN_SEC=0
ACTIVITY_EMAIL_MAX_HIGHLIGHTS=6
ACTIVITY_EMAIL_EXCLUDED_PATHS=/health,/health/ready,/api/otp
ACTIVITY_EMAIL_CTA_URL=http://localhost:5173/profile

# Order Email Fortress
ORDER_EMAILS_ENABLED=true
ORDER_EMAIL_PROVIDER=gmail
ORDER_EMAIL_FROM_NAME=Aura Marketplace
ORDER_EMAIL_FROM_ADDRESS=your-email@gmail.com
ORDER_EMAIL_REPLY_TO=support@example.com
ORDER_EMAIL_MAX_RETRIES=8
ORDER_EMAIL_WORKER_POLL_MS=10000
ORDER_EMAIL_ALERT_TO=ops@example.com
APP_PUBLIC_URL=http://localhost:5173

# Massive Catalog Fortress
CATALOG_IMPORTS_ENABLED=true
CATALOG_SYNC_ENABLED=true
CATALOG_ACTIVE_VERSION_REQUIRED=true
CATALOG_PUBLIC_DEMO_FALLBACK=false
CATALOG_SEARCH_INDEX_NAME=products_search_v1
CATALOG_SEARCH_CHECK_ON_BOOT=false
CATALOG_IMPORT_WORKER_POLL_MS=5000
CATALOG_SYNC_INTERVAL_MS=900000
CATALOG_DEFAULT_SYNC_PROVIDER=file
CATALOG_PROVIDER_SOURCE_REF=seeders/data/products.jsonl
CATALOG_PROVIDER_MANIFEST_REF=seeders/data/products.jsonl.manifest.json
CATALOG_IMPORT_AUDIT_SAMPLE_SIZE=1000
CATALOG_IMPORT_ALLOW_SYNTHETIC=false
CATALOG_READINESS_REQUIRE_PUBLISHED=true
CATALOG_ONBOARDING_SAMPLE_SIZE=200
CATALOG_SNAPSHOT_CACHE_DIR=.cache/catalog-snapshots
CATALOG_SNAPSHOT_SOURCE_TYPE=jsonl
CATALOG_SNAPSHOT_SOURCE_REF=
CATALOG_SNAPSHOT_MANIFEST_REF=
KAGGLE_BIN=kaggle
KAGGLE_DATASET=
KAGGLE_DATASET_FILE=
KAGGLE_SOURCE_FILE=
KAGGLE_ARCHIVE_PATH=
KAGGLE_IMAGE_BASE_URL=
KAGGLE_FIELD_MAP=
KAGGLE_SPEC_FIELDS=
KAGGLE_STRICT=true
KAGGLE_IMPORT_PUBLISH=false
COMMERCE_RECONCILIATION_ENABLED=true
COMMERCE_RECONCILIATION_POLL_MS=120000
FIRST_PARTY_CATALOG_SIZE=100000
FIRST_PARTY_CATALOG_VERSION=aura-firstparty-v1
FIRST_PARTY_CATALOG_BATCH_SIZE=1000

# Marketplace integrity
ALLOW_MARKETPLACE_DEMO_SEED=false
MARKETPLACE_MAX_IMAGE_BYTES=1500000

# Test DB controls
TEST_MONGO_URI=mongodb://127.0.0.1:27017/aura_test
TEST_USE_IN_MEMORY_MONGO=false
TEST_FALLBACK_TO_IN_MEMORY_MONGO=false

# Smoke / load validation identities
SMOKE_USER_EMAIL=
SMOKE_USER_PASSWORD=
SMOKE_USER_NAME=Smoke Customer
SMOKE_USER_PHONE=+919999999999
SMOKE_ADMIN_EMAIL=
SMOKE_ADMIN_PASSWORD=
SMOKE_ADMIN_NAME=Smoke Admin
SMOKE_ADMIN_PHONE=+919999999998
SMOKE_FIREBASE_API_KEY=
SMOKE_RAZORPAY_PAYMENT_ID=
