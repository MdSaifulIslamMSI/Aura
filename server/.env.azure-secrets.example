# Copy this file to server/.env.azure-secrets and fill the values locally.
# This file is intentionally gitignored when renamed without .example.
# Do not paste the values into chat or commit them to the repository.
#
# Future-proof runtime sync conventions:
# - Plain keys already present in the Azure appsetting templates are mirrored automatically.
# - Secret-like keys are auto-detected and pushed to Key Vault during sync.
# - Service-scoped keys can be added without touching the templates:
#   - SHARED__FEATURE_FLAG=true
#   - API__SOME_NEW_FLAG=true
#   - WORKER__SOME_NEW_FLAG=true
# Required for Azure production readiness
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional public routing overrides for Azure deploy scripts
# CORS_ORIGIN can be a comma-separated allowlist.
FRONTEND_URL=
CORS_ORIGIN=
APP_PUBLIC_URL=

# Optional but commonly needed in production
AZURE_KEY_VAULT_ENABLED=false
MONGO_URI=
REDIS_URL=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
GMAIL_USER=
GMAIL_APP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
GROQ_API_KEY=
VOYAGE_API_KEY=
ELEVENLABS_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SUPPORT_ROOM_PREFIX=
LIVEKIT_LISTING_ROOM_PREFIX=
AI_MODEL_PROVIDER=gemini
AI_MODEL_PROVIDER_FALLBACKS=
ASSISTANT_COMMERCE_REQUIRE_HOSTED_GEMMA=true
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=models/gemma-4-31b-it
GEMINI_CHAT_MODEL_FALLBACKS=models/gemma-4-26b-a4b-it
GEMINI_AUDIO_MODEL=models/gemma-3n-e4b-it
GEMINI_AUDIO_MODEL_FALLBACKS=models/gemma-3n-e2b-it
GEMINI_EMBED_MODEL=models/gemini-embedding-001
GEMINI_TIMEOUT_MS=45000
ASSISTANT_QUERY_EMBED_CACHE_TTL_MS=1800000
OLLAMA_BASE_URL=
OLLAMA_CHAT_MODEL=gemma4:e4b
OLLAMA_CHAT_MODEL_FALLBACKS=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=120000
OLLAMA_KEEP_ALIVE=15m

APP_BUILD_SHA=
ADMIN_REQUIRE_ALLOWLIST=true
ADMIN_ALLOWLIST_EMAILS=

# Existing auth/signing secrets you may want to preserve on first Azure cutover
AUTH_VAULT_SECRET=
AUTH_VAULT_PREVIOUS_SECRETS=
UPLOAD_SIGNING_SECRET=
OTP_FLOW_SECRET=
OTP_CHALLENGE_SECRET=
CRON_SECRET=
METRICS_SECRET=
