# Copy this file to server/.env.azure-secrets and fill the values locally.
# This file is intentionally gitignored when renamed without .example.
# Do not paste the values into chat or commit them to the repository.
#
# Future-proof runtime sync conventions:
# - Plain keys already present in the Azure appsetting templates are mirrored automatically.
# - Secret-like keys are auto-detected and pushed to Key Vault during sync.
# - Service-scoped keys can be added without touching the templates:
#   - SHARED__FEATURE_FLAG=true
#   - API__SOME_NEW_FLAG=true
#   - WORKER__SOME_NEW_FLAG=true
#   - INTELLIGENCE__SOME_NEW_FLAG=true

# Required for Azure production readiness
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional public routing overrides for Azure deploy scripts
# CORS_ORIGIN can be a comma-separated allowlist.
FRONTEND_URL=
CORS_ORIGIN=
APP_PUBLIC_URL=

# Optional but commonly needed in production
MONGO_URI=
REDIS_URL=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
GMAIL_USER=
GMAIL_APP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
GROQ_API_KEY=
VOYAGE_API_KEY=
ELEVENLABS_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SUPPORT_ROOM_PREFIX=
LIVEKIT_LISTING_ROOM_PREFIX=

# Central intelligence layer for Azure
CENTRAL_INTELLIGENCE_MODE=always
INTELLIGENCE_SERVICE_URL=
INTELLIGENCE_SERVICE_TIMEOUT_MS=12000
INTELLIGENCE_SERVICE_STREAM_TIMEOUT_MS=45000
INTELLIGENCE_SERVICE_TOKEN=
AI_INTERNAL_TOOL_SECRET=
INTELLIGENCE_PROVIDER=huggingface_inference_client
INTELLIGENCE_ROUTING_MODEL=google/gemma-4-31B-it:novita
INTELLIGENCE_REASONING_MODEL=google/gemma-4-31B-it:novita
INTELLIGENCE_ENDPOINT_API_KEY=
INTELLIGENCE_EMBEDDING_ENDPOINT_FORMAT=deterministic
INTELLIGENCE_EMBEDDING_MODEL=intfloat/multilingual-e5-large
INTELLIGENCE_EMBEDDING_VECTOR_SIZE=256
INTELLIGENCE_EMBEDDING_BATCH_SIZE=32
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=aura_code_chunks
QDRANT_DISTANCE=Cosine
QDRANT_UPSERT_BATCH_SIZE=128
NEO4J_URL=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_BATCH_SIZE=250
APP_BUILD_SHA=

# Existing auth/signing secrets you may want to preserve on first Azure cutover
AUTH_VAULT_SECRET=
AUTH_VAULT_PREVIOUS_SECRETS=
UPLOAD_SIGNING_SECRET=
OTP_FLOW_SECRET=
OTP_CHALLENGE_SECRET=
CRON_SECRET=
METRICS_SECRET=
