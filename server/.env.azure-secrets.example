# Copy this file to server/.env.azure-secrets and fill the values locally.
# This file is intentionally gitignored when renamed without .example.
# Do not paste the values into chat or commit them to the repository.

# Required for Azure production readiness
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional but commonly needed in production
MONGO_URI=
REDIS_URL=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
GMAIL_USER=
GMAIL_APP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
GROQ_API_KEY=
VOYAGE_API_KEY=
ELEVENLABS_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SUPPORT_ROOM_PREFIX=
LIVEKIT_LISTING_ROOM_PREFIX=

# Existing auth/signing secrets you may want to preserve on first Azure cutover
AUTH_VAULT_SECRET=
AUTH_VAULT_PREVIOUS_SECRETS=
UPLOAD_SIGNING_SECRET=
OTP_FLOW_SECRET=
OTP_CHALLENGE_SECRET=
CRON_SECRET=
METRICS_SECRET=
