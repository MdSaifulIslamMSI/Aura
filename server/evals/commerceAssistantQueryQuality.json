{
  "name": "commerce-assistant-query-quality",
  "version": 2,
  "description": "Fast local eval set for ecommerce assistant routing, filters, and deterministic retrieval query quality.",
  "cases": [
    {
      "id": "laptop-coding-gaming-budget",
      "message": "Suggest best laptop under 60000 for coding and gaming",
      "expect": {
        "route": "ECOMMERCE_SEARCH",
        "category": "Laptops",
        "maxPrice": 60000,
        "query": "laptop"
      }
    },
    {
      "id": "dell-laptops-in-stock",
      "message": "show me dell laptops under 50000 in stock",
      "expect": {
        "route": "ECOMMERCE_SEARCH",
        "category": "Laptops",
        "brand": "Dell",
        "maxPrice": 50000,
        "inStock": true,
        "query": "Dell laptop"
      }
    },
    {
      "id": "samsung-phones-budget",
      "message": "find samsung phones under 30000",
      "expect": {
        "route": "ECOMMERCE_SEARCH",
        "category": "Mobiles",
        "brand": "Samsung",
        "maxPrice": 30000,
        "query": "Samsung mobile phone"
      }
    },
    {
      "id": "top-rated-phones-in-stock",
      "message": "show top rated phones under 15000 in stock",
      "expect": {
        "route": "ECOMMERCE_SEARCH",
        "category": "Mobiles",
        "maxPrice": 15000,
        "inStock": true,
        "sortBy": "rating_desc"
      }
    },
    {
      "id": "budget-phones-sort",
      "message": "budget phones under 20000",
      "expect": {
        "route": "ECOMMERCE_SEARCH",
        "category": "Mobiles",
        "maxPrice": 20000,
        "sortBy": "price_asc"
      }
    },
    {
      "id": "premium-laptops-sort",
      "message": "show premium laptops under 120000",
      "expect": {
        "route": "ECOMMERCE_SEARCH",
        "category": "Laptops",
        "maxPrice": 120000,
        "sortBy": "price_desc"
      }
    },
    {
