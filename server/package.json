{
  "name": "server",
  "version": "1.1.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start_api_runtime.js",
    "start:workers": "node scripts/start_worker_runtime.js",
    "runtime:split:up": "docker compose -f ../docker-compose.split-runtime.yml up --build",
    "runtime:split:down": "docker compose -f ../docker-compose.split-runtime.yml down -v",
    "aws:ssm:sync": "powershell -ExecutionPolicy Bypass -File ../infra/aws/sync-parameter-store-env.ps1 -SourceEnvFile .env.aws-secrets",
    "aws:ssm:sync:example": "powershell -ExecutionPolicy Bypass -File ../infra/aws/sync-parameter-store-env.ps1 -SourceEnvFile .env.aws-secrets.example -DryRun",
    "aws:ssm:audit": "node scripts/audit_parameter_store_secret_contract.js",
    "smoke:bootstrap-accounts": "node scripts/assert_staging_smoke_safety.js --purpose=bootstrap && node scripts/bootstrap_staging_smoke_accounts.js",
    "smoke:staging": "node scripts/assert_staging_smoke_safety.js --purpose=smoke && node scripts/staging_smoke.js",
    "smoke:cross-domain-prod": "node scripts/verify_cross_domain_prod.js",
    "load:validate": "node scripts/load_validate.js",
    "search:report": "node scripts/search_relevance_report.js",
    "catalog:generate-demo-100k": "node scripts/generate_demo_catalog_snapshot.js",
    "catalog:seed-demo-100k": "node scripts/seed_demo_catalog_100k.js",
    "catalog:purge-demo": "node scripts/purge_demo_catalog.js --execute",
    "catalog:purge-jest-dbs": "node scripts/purge_jest_databases.js --execute",
    "catalog:kaggle:prepare": "node scripts/prepare_kaggle_catalog_snapshot.js",
    "catalog:kaggle:import": "node scripts/import_kaggle_catalog.js",
    "assistant:vectors:backfill": "node scripts/backfill_assistant_product_vectors.js",
    "assistant:eval:top100": "node scripts/eval_commerce_assistant_top100.js",
    "assistant:issue-internal-token": "node scripts/issue_internal_ai_service_token.js",
    "fx:refresh": "node scripts/refresh_fx_rates.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "test:transactions": "cross-env NODE_ENV=test TEST_REQUIRE_TRANSACTION_MONGO=true jest --runInBand",
    "seed": "node seeders/seed.js",
    "verify": "node scripts/verify_data.js",
    "catalog:audit-source": "node scripts/audit_catalog_source.js",
    "catalog:validate-snapshot": "node -e \"const { inspectCatalogSnapshot } = require('./services/catalogSnapshotService'); inspectCatalogSnapshot({ sourceType: process.env.CATALOG_SNAPSHOT_SOURCE_TYPE || 'jsonl', sourceRef: process.env.CATALOG_SNAPSHOT_SOURCE_REF, manifestRef: process.env.CATALOG_SNAPSHOT_MANIFEST_REF }).then((report) => { console.log(JSON.stringify(report, null, 2)); }).catch((error) => { console.error(error.message); process.exitCode = 1; });\"",
    "catalog:import": "node scripts/import_catalog_resumable.js",
    "catalog:seed-firstparty": "node scripts/seed_first_party_catalog.js",
    "seed:marketplace": "node scripts/seed_marketplace_listings.js",
    "marketplace:purge-demo": "node scripts/purge_demo_marketplace_data.js",
    "marketplace:reset-fresh": "node scripts/reset_marketplace_fresh.js --execute",
    "marketplace:reset-seller-state": "node scripts/reset_seller_state_fresh.js --execute",
    "migrate:drop-user-otp-ttl": "node scripts/drop_user_otp_ttl_index.js",
    "migrate:user-phone-sparse": "node scripts/migrate_user_phone_sparse_index.js",
    "migrate:catalog-backfill": "node scripts/backfill_catalog_version.js",
    "migrate:purge-legacy-cart": "node scripts/purge_legacy_user_cart.js",
    "wipe:firebase-auth": "node scripts/wipe_firebase_auth_users.js",
    "migrate:otp-session-identity": "node scripts/migrate_otp_session_identity_key.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/client-ssm": "^3.1040.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "cbor": "^9.0.2",
    "colors": "^1.4.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "livekit-server-sdk": "^2.15.2",
    "mongoose": "^9.6.1",
    "node-cron": "^4.2.1",
    "node-domexception": "file:vendor/node-domexception",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.7",
    "openai": "^4.85.2",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "resend": "^4.1.2",
    "socket.io": "^4.8.1",
    "stripe": "^22.1.0",
    "svix": "^1.92.2",
    "voyageai": "^0.2.1",
    "xss": "^1.0.15",
    "zod": "^3.24.2"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "gaxios": "^7.1.4",
    "glob": "^13.0.6",
    "google-gax": "^5.0.6",
    "http-proxy-agent": "^7.0.2",
    "node-domexception": "file:vendor/node-domexception",
    "protobufjs": "^7.5.5",
    "rimraf": "^6.1.3",
    "retry-request": "^8.0.2",
    "teeny-request": "^10.1.2",
    "test-exclude": "^8.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.1.3",
    "mongodb-memory-server-core": "^10.4.3",
    "supertest": "^7.2.2"
  }
}
