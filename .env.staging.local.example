# Local staging release-gate placeholders only.
# Do not put AWS access keys, session tokens, SSH keys, SSM values, API tokens,
# database URLs, auth secrets, payment secrets, or webhook secrets in this file.
# Prefer AWS SSO:
#   aws sso login --profile aura-staging-operator
#   AWS_PROFILE=aura-staging-operator

AWS_PROFILE=aura-staging-operator
AWS_REGION=ap-south-1

SMOKE_TARGET_ENV=staging
SMOKE_REQUIRE_BACKEND_STAGING=true
SMOKE_FORBID_PRODUCTION_ORIGINS=true

# Non-secret staging URLs. Replace with the isolated staging frontend/backend.
SMOKE_BASE_URL=https://staging.example.invalid
STAGING_BASE_URL=https://staging.example.invalid
STAGING_FRONTEND_URL=https://staging.example.invalid
STAGING_API_BASE_URL=https://api.staging.example.invalid
STAGING_HEALTH_URL=https://api.staging.example.invalid/health
STAGING_SSM_PREFIX=/aura/staging

# Non-secret production comparison URLs only. Never use these as staging targets.
PROD_BASE_URL=https://production.example.invalid
PROD_API_BASE_URL=https://api.production.example.invalid
PROD_SSM_PREFIX=/aura/prod
