{
    "buildCommand": "npm run build --prefix app",
    "outputDirectory": "app/dist",
    "rewrites": [
        {
            "source": "/socket.io",
            "destination": "https://13.206.172.186.sslip.io/socket.io/"
        },
        {
            "source": "/socket.io/",
            "destination": "https://13.206.172.186.sslip.io/socket.io/"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "https://13.206.172.186.sslip.io/socket.io/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "https://13.206.172.186.sslip.io/api/:path*"
        },
        {
            "source": "/health",
            "destination": "https://13.206.172.186.sslip.io/health"
        },
        {
            "source": "/health/ready",
            "destination": "https://13.206.172.186.sslip.io/health/ready"
        },
        {
            "source": "/health/live",
            "destination": "https://13.206.172.186.sslip.io/health/live"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://13.206.172.186.sslip.io/uploads/:path*"
        },
        {
            "source": "/:path((?!api/|socket\\.io(?:/|$)|uploads/|assets/|manifest\\.json$|sw\\.js$|favicon\\.ico$|robots\\.txt$|.*\\.[^/]+$).*)",
            "destination": "/index.html"
        }
    ]
}
