{
  "outputDirectory": "app/dist",
  "env": {
    "VITE_FIREBASE_PROJECT_ID": "@firebase_project_id",
    "VITE_API_URL": "@vite_api_url"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://aura-api-2dxo.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://aura-api-2dxo.onrender.com/health"
    },
    {
      "source": "/health/ready",
      "destination": "https://aura-api-2dxo.onrender.com/health/ready"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://aura-api-2dxo.onrender.com/uploads/$1"
    },
    {
      "source": "/((?!api/|uploads/|assets/|manifest\\.json$|sw\\.js$|favicon\\.ico$|robots\\.txt$|.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ]
}
